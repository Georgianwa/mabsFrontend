<%- include('partials/header') %>

<main class="category-page">
    <div class="page-header">
        <div class="container">
            <div class="breadcrumb">
                <a href="/">Home</a> / <a href="/categories">Categories</a> / <span><%= category.title %></span>
            </div>
            <h1><%= category.title %></h1>
            <% if (category.description) { %>
                <p><%= category.description %></p>
            <% } %>
        </div>
    </div>
    
    <section class="category-content">
        <div class="container">
            <div class="category-info">
                <p class="results-count">Showing <%= products.length %> products</p>
            </div>
            
            <% if (products.length > 0) { %>
                <div class="products-grid">
                    <% products.forEach(product => { %>
                        <div class="product-card">
                            <div class="product-image">
                                <a href="/product/<%= product._id || product.id %>">
                                    <% 
                                    let imageUrl = '';
                                    if (product.images && Array.isArray(product.images) && product.images.length > 0) {
                                        imageUrl = product.images[0];
                                    } else if (product.images && typeof product.images === 'string') {
                                        imageUrl = product.images;
                                    }
                                    %>
                                    <img src="<%= imageUrl || '/images/placeholder.jpg' %>" alt="<%= product.name %>">
                                </a>
                                <% if (product.featured) { %>
                                    <span class="badge">Featured</span>
                                <% } %>
                            </div>
                            <div class="product-info">
                                <p class="product-brand"><%= product.brand?.name || product.brand %></p>
                                <h3 class="product-name">
                                    <a href="/product/<%= product._id || product.id %>"><%= product.name %></a>
                                </h3>
                                <p class="product-description"><%= product.description.substring(0, 80) %>...</p>
                                <p class="product-price">₦<%= product.price ? product.price.toLocaleString() : '0' %></p>
                                <a href="/product/<%= product._id || product.id %>" class="btn btn-outline">View Details</a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="no-products">
                    <i class="fas fa-box-open"></i>
                    <p>No products available in this category at the moment.</p>
                    <a href="/categories" class="btn btn-primary">Browse Other Categories</a>
                </div>
            <% } %>
        </div>
        <div class="load-more-wrapper" style="text-align:center; margin-top:40px;">
            <button id="loadMoreBtn" class="btn btn-primary">
                Load more
            </button>
             <% if (isAdmin) { %>
                <button id="showAllBtn" class="btn btn-outline" style="margin-left:15px;">
                Show all (admin)
            </button>
            <% } %>
        </div>

    </section>
</main>
<script>
  window.PRODUCTS_PAGE = 1;
  window.PRODUCTS_LIMIT = 25;
  window.API_BASE_URL = "https://mabselectronicsbackend.onrender.com";
</script>
<script src="/js/loadMore.js"></script>

<%- include('partials/footer') %>